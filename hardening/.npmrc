# npm supply-chain hardening
# Reference: https://github.com/lirantal/npm-security-best-practices

# Prevent packages from running arbitrary scripts on install
ignore-scripts=true

# Pin exact versions — no semver ranges (^, ~)
save-exact=true

# Prefer pre-built binaries over compiling from source
prefer-binary=true

# Only allow packages that have been published for at least 7 days
# Mitigates supply-chain attacks via newly-published malicious versions
min-release-age=7
